# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Firebase Client Configuration (Vite/React prefix compatible with Google AI Studio & Vercel)
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""

# Whitelisted Administrative E-mails (Comma-separated)
# VITE_ADMIN_EMAILS is PUBLIC (UI gate only). Real auth = server ADMIN_EMAILS + Firestore rules + custom claims.
VITE_ADMIN_EMAILS="yunusemreyilmaz93@gmail.com"
ADMIN_EMAILS="yunusemreyilmaz93@gmail.com"

# API-Sports / API-Football Secret Key (Server / data-worker only — never VITE_)
# Free plan ≈ 100 req/day AND seasons 2022–2024 only (current Super Lig needs paid or TM).
# Nightly fixtures ≈ 1 req (season 2024 default).
APISPORTS_KEY=""
# API_FOOTBALL_KEY=""
# API_FOOTBALL_SEASON=2024
# API_FOOTBALL_ALLOW_CURRENT=1
# API_FOOTBALL_ALL_COMPETITIONS=1

# Optional: NODE_ENV=production hides API debug payloads

# Firebase App Check — reCAPTCHA v3 site key (public; from Firebase / reCAPTCHA admin)
# VITE_FIREBASE_APPCHECK_SITE_KEY=""
# Local only: true or a debug token UUID registered in Firebase App Check console
# VITE_FIREBASE_APPCHECK_DEBUG_TOKEN=true

# ── data-worker Firestore writes (A4) — SERVER / worker only, never VITE_ ──
# Path to service account JSON (Firebase Console → Project settings → Service accounts)
# FIREBASE_SERVICE_ACCOUNT_JSON="C:/secrets/fenerbahceevreni-sa.json"
# Or standard Google ADC path:
# GOOGLE_APPLICATION_CREDENTIALS="C:/secrets/fenerbahceevreni-sa.json"
# CI option (base64 of the JSON file):
# FIREBASE_SERVICE_ACCOUNT_JSON_B64=""
# Optional: job fails if Firestore not written
# (CLI flag) python data-worker/run_job.py --type health_probe --require-firestore

