rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net - deny all reads and writes by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    // Admin email whitelist check
    function isAdmin() {
      return request.auth != null && 
        (request.auth.token.email == "yunusemreyilmaz93@gmail.com");
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // ==========================================
    // 1. articles
    // ==========================================
    match /articles/{articleId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ==========================================
    // 2. matches
    // ==========================================
    match /matches/{matchId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ==========================================
    // 3. matchReports
    // ==========================================
    match /matchReports/{reportId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ==========================================
    // 4. players
    // ==========================================
    match /players/{playerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ==========================================
    // 5. transferReports
    // ==========================================
    match /transferReports/{reportId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ==========================================
    // 6. polls
    // ==========================================
    match /polls/{pollId} {
      allow read: if true;
      allow write: if isAdmin();
      
      // Dynamic subcollection under active polls for voting (conforming to Section 9 voting security)
      match /votes/{voteId} {
        allow read: if request.auth != null && request.auth.uid == voteId;
        allow create: if request.auth != null
                      && request.auth.uid == voteId
                      && get(/databases/$(database)/documents/polls/$(pollId)).data.status == "active"
                      && incoming().optionId is string
                      && incoming().optionId in get(/databases/$(database)/documents/polls/$(pollId)).data.options
                      && incoming().userId == request.auth.uid
                      && incoming().createdAt is string
                      && incoming().keys().hasAll(["optionId", "userId", "createdAt"])
                      && incoming().keys().size() == 3;
        allow update, delete: if isAdmin();
      }
    }

    // ==========================================
    // 7. newsletterSubscribers
    // ==========================================
    match /newsletterSubscribers/{subId} {
      allow read, update, delete: if isAdmin();
      allow create: if incoming().email is string 
                    && incoming().email.matches('^[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Za-z]{2,}$')
                    && incoming().status == "active"
                    && incoming().keys().hasAll(['email', 'status', 'subscribedAt'])
                    && incoming().keys().size() <= 15;
    }

    // ==========================================
    // 8. premiumWaitlist
    // ==========================================
    match /premiumWaitlist/{waitId} {
      allow read, update, delete: if isAdmin();
      allow create: if incoming().email is string 
                    && incoming().email.matches('^[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Za-z]{2,}$')
                    && incoming().keys().hasAll(['email', 'name', 'planInterest', 'status', 'createdAt'])
                    && incoming().keys().size() <= 15;
    }

    // ==========================================
    // 9. contactMessages
    // ==========================================
    match /contactMessages/{msgId} {
      allow read, update, delete: if isAdmin();
      allow create: if incoming().email is string 
                    && incoming().email.matches('^[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Za-z]{2,}$')
                    && incoming().status == "new"
                    && incoming().keys().hasAll(['name', 'email', 'subject', 'message', 'status', 'createdAt'])
                    && incoming().keys().size() <= 15;
    }

    // ==========================================
    // 10. sponsors
    // ==========================================
    match /sponsors/{sponsorId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ==========================================
    // 11. homepageSettings
    // ==========================================
    match /homepageSettings/{settingsId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ==========================================
    // 12. siteSettings
    // ==========================================
    match /siteSettings/{settingsId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ==========================================
    // 13. premiumContent
    // ==========================================
    match /premiumContent/{contentId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ==========================================
    // 14. newsletterIssues
    // ==========================================
    match /newsletterIssues/{issueId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ==========================================
    // 15. leagues
    // ==========================================
    match /leagues/{leagueId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ==========================================
    // 16. teams
    // ==========================================
    match /teams/{teamId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ==========================================
    // 17. fixtures
    // ==========================================
    match /fixtures/{fixtureId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ==========================================
    // 18. standings
    // ==========================================
    match /standings/{standingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ==========================================
    // 19. matchDetails
    // ==========================================
    match /matchDetails/{fixtureId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ==========================================
    // 20. homeSettings
    // ==========================================
    match /homeSettings/{settingsId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ==========================================
    // 21. announcements
    // ==========================================
    match /announcements/{announcementId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ==========================================
    // 22. media
    // ==========================================
    match /media/{mediaId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ==========================================
    // 23. sources
    // ==========================================
    match /sources/{sourceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ==========================================
    // 24. premium
    // ==========================================
    match /premium/{premiumId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ==========================================
    // 25. menus
    // ==========================================
    match /menus/{menuId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ==========================================
    // 26. categories
    // ==========================================
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ==========================================
    // 27. advancedPlayerStats
    // ==========================================
    match /advancedPlayerStats/{statId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ==========================================
    // 28. advancedMatchStats
    // ==========================================
    match /advancedMatchStats/{statId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ==========================================
    // 29. externalPlayerMappings (legacy alias)
    //     Kanonik ad: providerIds
    // ==========================================
    match /externalPlayerMappings/{mappingId} {
      allow read, write: if isAdmin();
    }

    // ==========================================
    // 30. dataSyncRuns (legacy alias)
    //     Kanonik ad: scrapeJobs
    // ==========================================
    match /dataSyncRuns/{runId} {
      allow read, write: if isAdmin();
    }

    // ==========================================
    // 31. providerIds (kanonik entity map)
    //     Doc ID = playerDocumentId
    // ==========================================
    match /providerIds/{playerDocumentId} {
      allow read, write: if isAdmin();
    }

    // ==========================================
    // 32. scrapeJobs (kanonik job log)
    // ==========================================
    match /scrapeJobs/{jobId} {
      allow read, write: if isAdmin();
    }
  }
}

