rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net - deny all reads and writes by default
    match /{document=**} {
      allow read, write: if false;
    }

    // ── Helpers ──────────────────────────────────────────────────────────
    // Prefer custom claim `admin: true` (set via Admin SDK). Email allowlist is fallback.
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.admin == true ||
        request.auth.token.email == "yunusemreyilmaz93@gmail.com"
      );
    }

    function isPremium() {
      return request.auth != null && request.auth.token.premium == true;
    }

    function incoming() {
      return request.resource.data;
    }

    function isValidEmail(value) {
      return value is string
        && value.size() >= 5
        && value.size() <= 254
        && value.matches('^[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Za-z]{2,}$');
    }

    function strMax(value, maxLen) {
      return value is string && value.size() > 0 && value.size() <= maxLen;
    }

    function optionalStrMax(value, maxLen) {
      return !(value is string) || value.size() <= maxLen;
    }

    // Public CMS: locked pieces require premium claim or admin
    function canReadPremiumDoc() {
      return isAdmin()
        || isPremium()
        || !('isLocked' in resource.data)
        || resource.data.isLocked != true
        || resource.data.get('visibility', 'public') == 'public'
        || resource.data.get('access', 'public') == 'public'
        || resource.data.get('teaserOnly', false) == true;
    }

    // ==========================================
    // 1. articles
    // ==========================================
    match /articles/{articleId} {
      allow read: if canReadPremiumDoc();
      allow write: if isAdmin();
    }

    // ==========================================
    // 2. matches
    // ==========================================
    match /matches/{matchId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ==========================================
    // 3. matchReports
    // ==========================================
    match /matchReports/{reportId} {
      allow read: if canReadPremiumDoc();
      allow write: if isAdmin();
    }

    // ==========================================
    // 4. players
    // ==========================================
    match /players/{playerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ==========================================
    // 5. transferReports
    // ==========================================
    match /transferReports/{reportId} {
      allow read: if canReadPremiumDoc();
      allow write: if isAdmin();
    }

    // ==========================================
    // 6. polls
    // Parent: public read, admin write only.
    // Votes: signed-in user creates own vote doc (uid == voteId). Aggregates via Admin SDK / API.
    // ==========================================
    match /polls/{pollId} {
      allow read: if true;
      allow write: if isAdmin();

      match /votes/{voteId} {
        allow read: if request.auth != null && (request.auth.uid == voteId || isAdmin());
        allow create: if request.auth != null
                      && request.auth.uid == voteId
                      && get(/databases/$(database)/documents/polls/$(pollId)).data.status == "active"
                      && incoming().optionId is string
                      && incoming().optionId.size() > 0
                      && incoming().optionId.size() <= 200
                      && incoming().optionId in get(/databases/$(database)/documents/polls/$(pollId)).data.options
                      && incoming().userId == request.auth.uid
                      && incoming().createdAt is string
                      && incoming().createdAt.size() <= 40
                      && incoming().keys().hasAll(["optionId", "userId", "createdAt"])
                      && incoming().keys().size() == 3;
        allow update, delete: if isAdmin();
      }
    }

    // ==========================================
    // 7. newsletterSubscribers
    // ==========================================
    match /newsletterSubscribers/{subId} {
      allow read, update, delete: if isAdmin();
      allow create: if isValidEmail(incoming().email)
                    && incoming().status == "active"
                    && incoming().subscribedAt is string
                    && incoming().subscribedAt.size() > 0
                    && incoming().subscribedAt.size() <= 40
                    && incoming().keys().hasAll(['email', 'status', 'subscribedAt'])
                    && incoming().keys().size() <= 12
                    && optionalStrMax(incoming().get('name', ''), 120)
                    && optionalStrMax(incoming().get('source', ''), 80)
                    && (!('interests' in incoming()) || (incoming().interests is list && incoming().interests.size() <= 20));
    }

    // ==========================================
    // 8. premiumWaitlist
    // ==========================================
    match /premiumWaitlist/{waitId} {
      allow read, update, delete: if isAdmin();
      allow create: if isValidEmail(incoming().email)
                    && strMax(incoming().name, 120)
                    && strMax(incoming().planInterest, 80)
                    && strMax(incoming().status, 40)
                    && strMax(incoming().createdAt, 40)
                    && incoming().keys().hasAll(['email', 'name', 'planInterest', 'status', 'createdAt'])
                    && incoming().keys().size() <= 12;
    }

    // ==========================================
    // 9. contactMessages
    // ==========================================
    match /contactMessages/{msgId} {
      allow read, update, delete: if isAdmin();
      allow create: if isValidEmail(incoming().email)
                    && strMax(incoming().name, 120)
                    && strMax(incoming().subject, 200)
                    && strMax(incoming().message, 5000)
                    && incoming().status == "new"
                    && strMax(incoming().createdAt, 40)
                    && incoming().keys().hasAll(['name', 'email', 'subject', 'message', 'status', 'createdAt'])
                    && incoming().keys().size() <= 16
                    && optionalStrMax(incoming().get('messageType', ''), 40)
                    && optionalStrMax(incoming().get('companyName', ''), 160)
                    && optionalStrMax(incoming().get('websiteUrl', ''), 300)
                    && optionalStrMax(incoming().get('budgetRange', ''), 80);
    }

    // ==========================================
    // 10. sponsors
    // ==========================================
    match /sponsors/{sponsorId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ==========================================
    // 11. homepageSettings
    // ==========================================
    match /homepageSettings/{settingsId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ==========================================
    // 12. siteSettings
    // ==========================================
    match /siteSettings/{settingsId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ==========================================
    // 13. premiumContent — set isLocked: true when paywall is needed
    // ==========================================
    match /premiumContent/{contentId} {
      allow read: if canReadPremiumDoc();
      allow write: if isAdmin();
    }

    // ==========================================
    // 14. newsletterIssues
    // ==========================================
    match /newsletterIssues/{issueId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ==========================================
    // 15. leagues
    // ==========================================
    match /leagues/{leagueId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ==========================================
    // 16. teams
    // ==========================================
    match /teams/{teamId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ==========================================
    // 17. fixtures
    // ==========================================
    match /fixtures/{fixtureId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ==========================================
    // 18. standings
    // ==========================================
    match /standings/{standingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ==========================================
    // 19. matchDetails
    // ==========================================
    match /matchDetails/{fixtureId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ==========================================
    // 20. homeSettings
    // ==========================================
    match /homeSettings/{settingsId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ==========================================
    // 21. announcements
    // ==========================================
    match /announcements/{announcementId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ==========================================
    // 22. media
    // ==========================================
    match /media/{mediaId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ==========================================
    // 23. sources
    // ==========================================
    match /sources/{sourceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ==========================================
    // 24. premium — set isLocked: true for full reports
    // ==========================================
    match /premium/{premiumId} {
      allow read: if canReadPremiumDoc();
      allow write: if isAdmin();
    }

    // ==========================================
    // 25. menus
    // ==========================================
    match /menus/{menuId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ==========================================
    // 26. categories
    // ==========================================
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ==========================================
    // 27. advancedPlayerStats
    // ==========================================
    match /advancedPlayerStats/{statId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ==========================================
    // 28. advancedMatchStats
    // ==========================================
    match /advancedMatchStats/{statId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ==========================================
    // 29. externalPlayerMappings (legacy) — admin only
    // ==========================================
    match /externalPlayerMappings/{mappingId} {
      allow read, write: if isAdmin();
    }

    // ==========================================
    // 30. dataSyncRuns (legacy) — admin only
    // ==========================================
    match /dataSyncRuns/{runId} {
      allow read, write: if isAdmin();
    }

    // ==========================================
    // 31. providerIds — admin only
    // ==========================================
    match /providerIds/{playerDocumentId} {
      allow read, write: if isAdmin();
    }

    // ==========================================
    // 32. scrapeJobs — admin only
    // ==========================================
    match /scrapeJobs/{jobId} {
      allow read, write: if isAdmin();
    }

    // ==========================================
    // 33. rateLimitBuckets — admin only
    // ==========================================
    match /rateLimitBuckets/{bucketId} {
      allow read, write: if isAdmin();
    }
  }
}
